{
  "name": "@ozura/storefront-sdk",
  "version": "0.3.1",
  "description": "Read products, create carts, and tail orders against an Ozura merchant — server-side SDK for the Ozura storefront API.",
  "license": "MIT",
  "homepage": "https://github.com/Ozura-Inc/ozura-storefront-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ozura-Inc/ozura-storefront-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Ozura-Inc/ozura-storefront-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ozura",
    "storefront",
    "sdk",
    "ecommerce",
    "checkout"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
