{
  "name": "@ozura/storefront-sdk",
  "version": "0.4.0-alpha.2",
  "description": "Read products, create carts, and tail orders against an Ozura merchant — server-side SDK for the Ozura storefront API. Ships the browser-side storefront runtime as a CDN-linkable asset.",
  "license": "MIT",
  "homepage": "https://github.com/Ozura-Inc/ozura-storefront-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ozura-Inc/ozura-storefront-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Ozura-Inc/ozura-storefront-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./dist/runtime/storefront.js": "./dist/runtime/storefront.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "sync:agents": "node scripts/sync-agent-guidance.mjs",
    "build:lib": "tsup src/index.ts src/runtime/index.ts --format cjs,esm --dts --clean",
    "build:runtime-asset": "node scripts/emit-runtime.mjs",
    "build": "npm run sync:agents && npm run build:lib && npm run build:runtime-asset",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ozura",
    "storefront",
    "sdk",
    "ecommerce",
    "checkout"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
